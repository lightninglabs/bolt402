# === AI Provider (required — pick ONE) ===
# The demo auto-detects which key is set. Priority: Anthropic > xAI > OpenAI.
# Optionally override the model with AI_MODEL.

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_AUTH_TOKEN=sk-ant-oat-...  # OAuth token from `claude setup-token`
# AI_MODEL=claude-sonnet-4-20250514

# xAI (Grok)
# XAI_API_KEY=xai-...
# AI_MODEL=grok-3-mini

# OpenAI
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o

# Lightning Backend: lnd | swissknife (required)
BACKEND_TYPE=swissknife

# === LND ===
# LND_URL=https://umbrel.local:8080
# LND_MACAROON=<hex-encoded macaroon, see README for budget-limited setup>
# Uncomment if LND uses self-signed TLS cert:
# NODE_TLS_REJECT_UNAUTHORIZED=0

# === SwissKnife ===
# SWISSKNIFE_URL=https://api.numeraire.tech
# SWISSKNIFE_API_KEY=your_api_key

# 402index.io API (optional, defaults to https://402index.io/api/v1)
# INDEX_API_URL=https://402index.io/api/v1
