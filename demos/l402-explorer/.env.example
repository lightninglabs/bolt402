# === AI Provider (required — pick ONE) ===
# The demo auto-detects which key is set. Priority: Anthropic > xAI > OpenAI.
# Optionally override the model with AI_MODEL.

# Anthropic (Claude)
# Use ANTHROPIC_API_KEY for standard API keys (sk-ant-api03-...)
# Use ANTHROPIC_AUTH_TOKEN for OAuth tokens from `claude setup-token` (sk-ant-oat...)
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-20250514

# xAI (Grok)
# XAI_API_KEY=xai-...
# AI_MODEL=grok-3-mini

# OpenAI
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o

# Lightning Backend: lnd | swissknife | mock (default: mock)
# Start with mock to test the UI, then switch to lnd or swissknife for real payments.
BACKEND_TYPE=mock

# === LND ===
# LND_URL=https://umbrel.local:8080
# LND_MACAROON=<hex-encoded macaroon, see README for budget-limited setup>
# Uncomment if LND uses self-signed TLS cert:
# NODE_TLS_REJECT_UNAUTHORIZED=0

# === SwissKnife ===
# SWISSKNIFE_URL=https://app.numeraire.tech
# SWISSKNIFE_API_KEY=your_api_key

# Satring API (optional, defaults to https://satring.com/api/v1)
# SATRING_API_URL=https://satring.com/api/v1
