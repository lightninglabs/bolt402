{
  "name": "@lightninglabs/bolt402-ai",
  "version": "0.0.0",
  "description": "L402 Lightning payment tools for the Vercel AI SDK. Let AI agents pay for APIs with Bitcoin.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "l402",
    "lightning",
    "bitcoin",
    "ai",
    "vercel",
    "ai-sdk",
    "agent",
    "payments"
  ],
  "packageManager": "yarn@4.13.0",
  "author": "Dario Anongba Varela <dario.anongba@gmail.com>",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/lightninglabs/bolt402.git",
    "directory": "packages/bolt402-ai-sdk"
  },
  "homepage": "https://github.com/lightninglabs/bolt402",
  "peerDependencies": {
    "ai": ">=6.0.0",
    "zod": "^3.25.76 || ^4.1.8"
  },
  "dependencies": {
    "bolt402-wasm": "file:../../crates/bolt402-wasm/pkg"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "ai": "^6.0.116",
    "eslint": "^9.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "zod": "^3.25.76"
  }
}
